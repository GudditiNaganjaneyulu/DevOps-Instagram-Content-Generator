# ─── Backend ──────────────────────────────────────────────────────────────────
# MongoDB Atlas (free tier) — replace <user>/<pass>/<cluster>
MONGODB_URL=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/devops_emotions?retryWrites=true&w=majority
MONGODB_DB_NAME=devops_emotions

# Upstash Redis (free tier) — copy from Upstash dashboard
REDIS_URL=rediss://:password@xxxxx.upstash.io:6379

# Cloudinary (free tier)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_UPLOAD_PRESET=devops_emotions

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Groq — https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Google AI Studio (Gemini) — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxx

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxx

# Hugging Face — https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxx

# Stable Horde — https://stablehorde.net/register (100% free, crowdsourced GPUs)
# "0000000000" works as anonymous key without registering (lower priority queue)
STABLE_HORDE_API_KEY=hSFxCR610cK4OS4u5IabQQ

# Fal.ai — https://fal.ai/dashboard/keys (free $10 credits on signup, no card needed)
FAL_API_KEY=xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxx

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ─── OAuth ────────────────────────────────────────────────────────────────────
# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# GitHub OAuth — https://github.com/settings/developers
GITHUB_ID=xxxxxxxxxxxxxxxxxxxx
GITHUB_SECRET=xxxxxxxxxxxxxxxxxxxx

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_me_to_another_long_random_secret

# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
DAILY_GENERATION_LIMIT=5
SCHEDULER_HOUR=9
SCHEDULER_MINUTE=0

# ─── Reddit (optional — public API works without keys) ────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=DevOpsEmotions/1.0
